  "settings": [
    {
      "type": "text",
      "id": "storefront_token",
      "label": "Storefront Access Token",
      "default": "09e36a43315b4c8cfa1c5548a6861727"
    }
  ],
  "templates": ["product"],
  "presets": [
    {
      "name": "Lobobot Product Detail",
      "category": "Custom"
    }
  ]
}
{% endschema %}
